# ============================================
# ST/ST Virtual Try-On — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit secrets.

# ── Decart API (required) ──────────────────────
# Your permanent Decart API key (server-side only).
# Get one at https://platform.decart.ai
DECART_API_KEY=sk-your-decart-api-key-here

# ── App Configuration ──────────────────────────
# Environment: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# Show API key input in sidebar for direct testing (dev/demo only).
# Set to false in staging and production.
NEXT_PUBLIC_DEV_MODE=true

# Maximum VTO session duration in seconds (0 = unlimited).
# Recommended: 300 (5 min) to manage API costs.
NEXT_PUBLIC_MAX_SESSION_SECONDS=300

# ── Analytics (Phase 2) ───────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Rate Limiting (Phase 2) ───────────────────
# Max token requests per minute per IP
# RATE_LIMIT_RPM=10
